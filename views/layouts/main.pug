doctype html
html(lang="en")
    head
        meta(charset="UTF-8")
        meta(name="viewport", content="width=device-width, initial-scale=1.0")
        link(rel="icon", type="image/svg+xml", href="/icons/favicon.svg")
        link(rel="stylesheet", href="/css/output.css")
        title Fotaza 2
    body(
        class="bg-bk min-h-screen min-w-full font-sans antialiased relative"
        data-toast=(toast || undefined)
        data-toast-type=toastType
    )
        main 
            block content

        footer(class="absolute bottom-0 left-0 w-full flex items-center justify-center text-sm text-black opacity-60") Fotaza 2 - No esta afiliada con ninguna gran empresa tecnologica

        script(type="module").
            import { showToast } from "/js/helpers/toast.js";
            const msg = document.body.dataset.toast;
            if (msg) showToast(msg, document.body.dataset.toastType || "info");
