include ./publicationCard.pug

mixin feedGrid(publications, endpoint, hasMore, gridClass, emptyMsg)
    if !publications || !publications.length
        p(class="text-sm text-black opacity-60 p-4")= emptyMsg || "Todavia no hay publicaciones para mostrar."
    else
        div(
            data-feed-grid
            data-feed-endpoint=endpoint
            data-feed-page="1"
            data-feed-done=String(!hasMore)
            class=`grid ${gridClass} gap-4 items-start`
        )
            each pub in publications
                +publicationCard(pub, pub.author, Boolean(user) && pub.author && pub.author.id === user.id)

        if hasMore
            div(data-feed-sentinel class="w-full flex items-center justify-center py-6 text-sm text-black opacity-60") Cargando mas...
