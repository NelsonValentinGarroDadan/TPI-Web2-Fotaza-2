include ./win-border.pug
include ./icon.pug

mixin pmSection(title)
    div(class="bg-white border-2 border-black")
        div(class="bg-linear-to-r from-blue to-blue-l px-3 py-1")
            h3(class="text-white font-bold text-sm")= title
        div(class="p-3")
            block

mixin publicationModal()
    div(data-pub-modal data-authenticated=String(Boolean(user)) data-user-id=(user ? user.id : "") class="hidden fixed inset-0 z-50 items-center justify-center p-4")
        div(data-modal-backdrop class="absolute inset-0 bg-black/60")

        div(class="relative w-[90vw] max-w-7xl h-[95vh] flex flex-col overflow-hidden bg-bk border-2 border-black")

            div(class="w-full flex items-center justify-between gap-2 bg-linear-to-r from-blue to-blue-l px-3 py-1")
                h2(data-pv-title class="text-white font-bold text-sm truncate") Publicacion
                div(class="shrink-0 flex items-center gap-2")
                    a(
                        data-pv-edit
                        href="#"
                        title="Editar publicacion"
                        class="hidden items-center justify-center bg-win-gray-l hover:bg-win-gray text-white border-2 border-black cursor-pointer px-1"
                    )
                        +icon("gear", "h-4 w-4")
                    button(
                        type="button"
                        data-modal-close
                        class="flex items-center justify-center h-5 bg-red-500 hover:bg-red-700 text-white border-2 border-black cursor-pointer py-2 px-1"
                    ) ✕

            div(class="flex-1 min-h-0 flex flex-col gap-4 p-4")

                div(class="flex-1 min-h-0 flex flex-col lg:flex-row gap-4")

                    div(class="flex-1 min-w-0 h-72 lg:h-auto relative overflow-hidden bg-win-gray-l/30 border-2 border-black")
                        img(data-pv-bg src="" alt="" aria-hidden="true" class="absolute inset-0 w-full h-full object-cover blur-2xl scale-110 opacity-50")
                        img(data-pv-image src="" alt="" class="absolute inset-0 w-full h-full object-contain")
                        button(type="button" data-pv-prev class="hidden absolute left-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-white/80 hover:bg-white border-2 border-black text-black text-lg leading-none cursor-pointer") ‹
                        button(type="button" data-pv-next class="hidden absolute right-2 top-1/2 -translate-y-1/2 w-8 h-8 bg-white/80 hover:bg-white border-2 border-black text-black text-lg leading-none cursor-pointer") ›
                        span(data-pv-counter class="hidden absolute bottom-2 right-2 bg-black/60 text-white text-xs px-2 py-0.5")

                    div(class="w-full lg:w-90 shrink-0 flex flex-col gap-3 min-h-0 overflow-y-auto")

                        div(data-hide-owner)
                            +pmSection("Autor")
                                div(class="flex items-center gap-3")
                                    img(data-pv-author-img src="/imgs/profile_img_default.png" alt="Foto de perfil" class="w-12 h-12 object-cover border-2 border-black")
                                    div(class="flex flex-col min-w-0")
                                        span(data-pv-author-name class="text-sm font-bold text-black truncate") @usuario
                                        a(data-pv-profile-link href="#" class="text-xs text-blue-l hover:text-blue underline") Ver perfil
                                    button(type="button" data-pv-follow class="hidden ml-auto shrink-0 px-3 py-1 text-sm border border-black cursor-pointer") Seguir

                        +pmSection("Descripcion")
                            p(data-pv-description class="text-sm text-black opacity-80 whitespace-pre-line mb-3")
                            div(data-pv-tags class="flex flex-wrap gap-2")

                        +pmSection("Calificacion")
                            div(class="flex items-center gap-2 mb-2")
                                span(data-pv-stars class="text-yellow-500 text-lg leading-none") ☆☆☆☆☆
                                span(data-pv-rating class="text-sm font-bold text-black") 0
                                span(data-pv-rating-count class="text-xs text-black opacity-60") (0)
                            div(data-pv-rate-box data-hide-owner)
                                p(class="text-sm text-black mb-1") Califica esta foto:
                                div(class="flex items-center gap-2")
                                    div(data-pv-rate class="text-2xl leading-none flex gap-1 select-none")
                                    button(
                                        type="button"
                                        data-pv-rate-confirm
                                        title="Confirmar calificacion"
                                        class="hidden w-6 h-6 shrink-0 bg-green-600 hover:bg-green-700 text-white border-2 border-black cursor-pointer items-center justify-center"
                                    ) ✓
                            p(data-pv-rated-msg class="hidden text-sm font-bold text-black")

                        div(data-hide-owner class="flex items-stretch gap-2")
                            div(data-pv-interest-wrap class="flex-1")
                                +winBorder("w-full h-full")
                                    button(type="button" data-pv-interest class="w-full h-full px-4 py-2 bg-win-gray/20 hover:bg-win-gray/40 text-sm text-black cursor-pointer") Me interesa obtenerla
                            +winBorder()
                                button(type="button" data-pv-report title="Reportar" class="h-full px-3 py-2 bg-win-gray/20 hover:bg-win-gray/40 text-red-500 cursor-pointer flex items-center justify-center")
                                    +icon("flag", "w-5 h-5")

                div(class="shrink-0 h-70 flex flex-col bg-white border-2 border-black")
                    div(class="shrink-0 bg-linear-to-r from-blue to-blue-l px-3 py-1")
                        h3(class="text-white font-bold text-sm") Comentarios (#[span(data-pv-comments-count) 0])
                    div(class="flex-1 min-h-0 p-3 flex flex-col lg:flex-row gap-3")
                        div(class="flex-1 min-w-0 flex flex-col gap-2")
                            div(data-pv-comment-form class="flex flex-col gap-2")
                                +winBorder("w-full")
                                    textarea(data-pv-comment-input maxlength="250" class="w-full h-16 resize-none text-sm text-black px-2 py-1" placeholder="Escribi un comentario...")
                                div(class="flex justify-end")
                                    +winBorder()
                                        button(type="button" data-pv-comment-send class="px-4 py-1 bg-win-gray/30 hover:bg-win-gray/50 text-sm text-black cursor-pointer") Comentar
                            p(data-pv-comments-disabled class="hidden text-xs text-black opacity-60") Los comentarios estan deshabilitados en esta publicacion.
                        div(data-pv-comments class="w-[50%] min-w-0 min-h-0 overflow-y-auto flex flex-col gap-2")
