include ./icon.pug
include ./win-border.pug

mixin navItem(id,icon, label, active, vertical, activeClass, normalClass, extraClass)
    -
        const layout = vertical ? "flex-col" : "flex-row"
        const active_ = activeClass || "text-white bg-win-gray/40 hover:bg-win-gray/50"
        const normal_ = normalClass || "text-black hover:text-white hover:bg-win-gray/50"
        const variant = active ? active_ : normal_
        const extra = extraClass || ""
        const finalClass = `flex items-center justify-center gap-1 py-1 px-3 cursor-pointer ${layout} ${variant} ${extra}`
    +winBorder()
        button(
            type="button"
            class=finalClass
            id=id
        )
            +icon(icon, "w-6 h-6")
            span(class="text-xs") #{label}
