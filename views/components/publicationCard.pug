include ./win-border.pug
include ./icon.pug

mixin publicationCard(pub, author, owner)
    -
        const imgs = (pub.images || []).map((i) => (typeof i === "string" ? { url: i } : i))
        const rating = pub.rating || 0
        const fullStars = Math.round(rating)
        const commentsCount = pub.commentsCount || 0
        const modalData = {
            id: pub.id,
            canEdit: pub.canEdit,
            title: pub.title,
            description: pub.description,
            tags: pub.tags || [],
            images: imgs,
            commentsEnabled: pub.commentsEnabled !== false,
            author: { nickname: author.nickname, profile_img: author.profile_img, id: author.id },
        }

    div(data-pub data-owner=String(!!owner) data-publication=JSON.stringify(modalData) class="relative")

        if owner && pub.canEdit
            a(
                href=`/upload/${pub.id}/edit`
                title="Editar publicacion"
                class="absolute top-1 right-1 z-10 flex items-center justify-center bg-win-gray-l border-2 border-black text-white hover:bg-win-gray cursor-pointer px-1"
            )
                +icon("gear", "w-4 h-4")

        button(
            type="button"
            data-card
            class="group w-full text-left bg-white border-2 border-black cursor-pointer flex flex-col overflow-hidden"
        )

            div(class="shrink-0 bg-linear-to-r from-blue to-blue-l px-3 py-1")
                h3(class="text-white font-bold text-sm truncate")= pub.title || "Publicacion"

            div(class="relative aspect-4/3 overflow-hidden bg-win-gray-l/40")
                img(src=pub.cover alt=(pub.title || "") class="w-full h-full object-cover transition-none group-hover:scale-105")
                if pub.imageCount > 1
                    span(class="absolute bottom-1 right-1 bg-black/60 text-white text-xs px-2 py-0.5") #{pub.imageCount}

            div(class="shrink-0 p-3 flex flex-col gap-2")

                div(class="flex flex-col min-w-0")
                    span(class="text-black font-bold text-sm truncate")= pub.title || "Publicacion"
                    if !owner
                        span(class="text-xs text-blue-l truncate") by #{author.nickname || "usuario"}

                div(class="flex items-center gap-2")
                    span(data-card-stars class="text-yellow-500 text-lg leading-none")
                        each _, i in [0, 1, 2, 3, 4]
                            if i < fullStars
                                | ★
                            else
                                | ☆
                    span(data-card-rating class="text-xs text-black opacity-60") (#{rating})

                div(class="border-t border-win-gray pt-2 flex items-stretch gap-2")
                    +winBorder("flex-1")
                        span(class="flex items-center justify-center gap-2 px-3 py-1 bg-win-gray/20 text-sm text-black w-full")
                            svg(xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" class="w-4 h-4")
                                path(d="M4 4h16v12H7l-3 3z")
                            span(data-card-comments) #{commentsCount}
