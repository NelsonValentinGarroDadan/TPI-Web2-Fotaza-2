include ./win-border.pug

mixin reportDialog()
    div(data-report-dialog class="absolute inset-0 z-50 flex items-center justify-center p-4 opacity-0 pointer-events-none transition-opacity duration-150")
        div(data-report-backdrop class="absolute inset-0 bg-black/60")

        div(class="relative w-[90vw] max-w-md flex flex-col bg-bk border-2 border-black")
            div(class="flex items-center justify-between gap-2 bg-linear-to-r from-blue to-blue-l px-3 py-1")
                h3(data-report-title class="text-white font-bold text-sm") Denunciar
                button(
                    type="button"
                    data-report-cancel
                    class="flex items-center justify-center h-5 bg-red-500 hover:bg-red-700 text-white border-2 border-black cursor-pointer py-2 px-1"
                ) ✕

            div(class="p-4 flex flex-col gap-3")
                div(class="flex flex-col gap-1")
                    label(class="text-sm font-bold text-black") Motivo
                    select(data-report-reason class="w-full border-2 border-black text-sm text-black px-2 py-1 bg-white")
                        option(value="inapropiado") Contenido inapropiado
                        option(value="spam") Spam o enganoso
                        option(value="derechos") Derechos de autor
                        option(value="violencia") Violencia o contenido sensible
                        option(value="otro") Otro
                div(class="flex flex-col gap-1")
                    label(class="text-sm font-bold text-black") Descripcion
                    +winBorder("w-full")
                        textarea(data-report-description maxlength="250" class="w-full h-20 resize-none text-sm text-black px-2 py-1" placeholder="Conta por que estas denunciando...")
                p(data-report-error class="h-5 text-sm text-red-500")
                div(class="flex justify-end gap-2")
                    +winBorder()
                        button(type="button" data-report-cancel class="px-4 py-1 bg-win-gray/30 hover:bg-win-gray/50 text-sm text-black cursor-pointer") Cancelar
                    +winBorder()
                        button(type="button" data-report-submit class="px-4 py-1 bg-red-500 hover:bg-red-700 text-sm text-white border border-black cursor-pointer") Enviar denuncia
