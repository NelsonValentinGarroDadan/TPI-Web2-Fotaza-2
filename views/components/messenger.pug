include ./icon.pug

mixin messenger()
    div(data-messenger class="fixed bottom-0 right-2 sm:right-4 z-40 w-80 max-w-[calc(100vw-1rem)] flex flex-col")

        button(
            type="button"
            data-msg-toggle
            class="flex items-center justify-between gap-2 bg-linear-to-r from-blue to-blue-l px-3 py-2 border-2 border-black cursor-pointer text-white"
        )
            span(class="flex items-center gap-2 font-bold text-sm")
                +icon("chats", "w-5 h-5")
                | Mensajes
            span(class="flex items-center gap-2")
                span(data-msg-badge class="hidden min-w-5 h-5 px-1 bg-red-500 text-white text-xs font-bold flex items-center justify-center border border-black") 0
                span(data-msg-caret) ▴

        div(data-msg-panel class="hidden flex-col bg-bk border-2 border-t-0 border-black h-96 max-h-[70vh]")

            div(data-msg-list-view class="flex-1 min-h-0 flex flex-col")
                div(data-msg-list class="flex-1 min-h-0 overflow-y-auto flex flex-col")
                p(data-msg-empty class="hidden p-4 text-sm text-black opacity-60 text-center") Todavia no tenes conversaciones. Toca "Me interesa" en una imagen con licencia para empezar a chatear con el autor.

            div(data-msg-chat-view class="hidden flex-1 min-h-0 flex flex-col")
                div(class="shrink-0 flex items-center gap-2 bg-white border-b-2 border-black px-2 py-1")
                    button(
                        type="button"
                        data-msg-back
                        title="Volver"
                        class="shrink-0 w-7 h-7 bg-win-gray/30 hover:bg-win-gray/50 border border-black text-black text-lg leading-none cursor-pointer"
                    ) ‹
                    img(data-msg-chat-avatar src="/imgs/profile_img_default.png" alt="" class="w-7 h-7 object-cover border border-black")
                    a(data-msg-chat-name href="#" class="text-sm font-bold text-black truncate hover:text-blue-l") @usuario
                    img(data-msg-chat-thumb src="" alt="" class="ml-auto w-9 h-9 object-cover border border-black")

                div(data-msg-messages class="flex-1 min-h-0 overflow-y-auto p-2 flex flex-col gap-2 bg-win-gray-l/20")

                form(data-msg-form class="shrink-0 flex items-stretch gap-1 border-t-2 border-black p-2 bg-white")
                    input(
                        data-msg-input
                        type="text"
                        maxlength="1000"
                        autocomplete="off"
                        placeholder="Escribi un mensaje..."
                        class="flex-1 min-w-0 text-sm text-black border border-black px-2 py-1 outline-none focus:border-blue"
                    )
                    button(
                        type="submit"
                        class="shrink-0 px-3 bg-blue-l hover:bg-blue text-white text-sm border border-black cursor-pointer"
                    ) Enviar
