extend ../layouts/app.pug
include ../components/win-border.pug

block app
    main(class="flex flex-col items-center justify-start w-full py-8 px-4")
        +winBorder("w-full max-w-xl")
            section(class="bg-white w-full")

                div(class="w-full flex items-center justify-start bg-linear-to-r from-blue to-blue-l px-2 gap-1")
                    img(
                        src="/icons/user-bold.svg"
                        class="w-6 h-6"
                        alt="Icono de usuario"
                    )
                    h1(class="text-white w-full font-bold text-sm py-1") Mi perfil - Fotaza 2

                form(
                    id="form-profile"
                    class="flex flex-col items-center justify-start gap-4 p-6 w-full"
                )

                    label(for="profile_img" class="relative w-28 h-28 block")
                        +winBorder("w-full h-full")
                            img(
                                src=(profile.profile_img || "/imgs/profile_img_default.png")
                                alt="Foto de perfil"
                                class="w-full h-full object-cover bg-white"
                                id="profile_img_preview"
                            )
                        span(
                            data-edit
                            class="hidden absolute -bottom-2 -right-2 bg-blue border-2 border-black w-7 h-7 flex items-center justify-center cursor-pointer"
                        )
                            img(src="/icons/camera.svg" class="w-4 h-4")
                        input(
                            type="file"
                            accept="image/*"
                            name="profile_img"
                            id="profile_img"
                            data-edit
                            disabled
                            class="hidden"
                        )

                    div(class="w-full flex flex-col items-center gap-1")
                        p(
                            data-view
                            class="text-2xl font-bold text-black"
                        ) #{profile.nickname}
                        div(data-edit class="hidden w-full")
                            +winBorder("w-full")
                                input(
                                    type="text"
                                    name="nickname"
                                    id="nickname"
                                    value=profile.nickname
                                    class="text-black text-center text-lg w-full px-2 py-1"
                                )
                            span#nickname-error(class="block text-red-500 text-sm h-4 w-full text-center")

                    div(class="flex items-center justify-center gap-10")
                        div(class="flex flex-col items-center")
                            span(class="text-xl font-bold text-black") #{profile.followers}
                            span(class="text-xs text-black opacity-70") Seguidores
                        +winBorder("self-stretch")
                            div(class="w-[1px] h-full")
                        div(class="flex flex-col items-center")
                            span(class="text-xl font-bold text-black") #{profile.following}
                            span(class="text-xs text-black opacity-70") Seguidos

                    div(class="w-full flex flex-col items-center gap-1")
                        p(
                            data-view
                            class="text-sm text-black opacity-80 text-center whitespace-pre-line"
                        ) #{profile.biography || "Todavia no escribiste una biografia."}
                        div(data-edit class="hidden w-full")
                            +winBorder("w-full")
                                textarea(
                                    name="biography"
                                    id="biography"
                                    class="text-black text-sm h-20 w-full resize-none px-2 py-1"
                                    placeholder="Contanos algo sobre vos..."
                                )= profile.biography || ""
                            span#biography-error(class="block text-red-500 text-sm h-4 w-full text-center")

                    div#form-error(class="text-red-500 text-sm w-full text-center h-4")

                    div(class="flex items-center justify-center gap-3")
                        div(data-view)
                            +winBorder()
                                button(
                                    type="button"
                                    id="btn-edit"
                                    class="px-4 py-2 bg-win-gray/30 hover:bg-win-gray/50 text-sm text-black cursor-pointer"
                                ) Editar perfil
                        div(data-edit class="hidden")
                            +winBorder()
                                button(
                                    type="submit"
                                    id="btn-save"
                                    class="px-4 py-2 bg-blue-l hover:bg-blue text-sm text-white border border-black cursor-pointer"
                                ) Guardar
                        div(data-edit class="hidden")
                            +winBorder()
                                button(
                                    type="button"
                                    id="btn-cancel"
                                    class="px-4 py-2 bg-win-gray/30 hover:bg-win-gray/50 text-sm text-black cursor-pointer"
                                ) Cancelar

        script(src="/js/helpers/errors.js" type="module")
        script(src="/js/helpers/validator.js" type="module")
        script(src="/js/user/schemas.js" type="module")
        script(src="/js/user/senders.js" type="module")
        script(src="/js/user/profile.js" type="module")
