extend ./layouts/app.pug
include ./components/win-border.pug
include ./components/feedGrid.pug
include ./components/publicationModal.pug

block app
    section(class="flex flex-col items-center w-full py-8 px-4")
        div(class="w-[90vw] max-w-6xl flex flex-col gap-4")

            form(method="GET" action="/search" class="bg-white border-2 border-black p-4 flex flex-col gap-3")
                +winBorder("w-full")
                    input(
                        type="text"
                        name="q"
                        value=q
                        placeholder="Busca por palabras clave o #etiquetas..."
                        class="text-black text-sm w-full px-2 py-1"
                    )
                div(class="flex flex-wrap items-end gap-3")
                    div(class="flex flex-col gap-1")
                        label(class="text-xs text-black") Valoracion minima
                        +winBorder()
                            input(type="number" name="minRating" min="0" max="5" step="0.5" value=minRating class="text-black text-sm w-24 px-2 py-1")
                    div(class="flex flex-col gap-1")
                        label(class="text-xs text-black") Valoracion maxima
                        +winBorder()
                            input(type="number" name="maxRating" min="0" max="5" step="0.5" value=maxRating class="text-black text-sm w-24 px-2 py-1")
                    +winBorder()
                        button(type="submit" class="px-4 py-2 bg-blue-l hover:bg-blue text-white text-sm cursor-pointer") Buscar

            +feedGrid(publications, endpoint, hasMore, "grid-cols-1 sm:grid-cols-2 lg:grid-cols-3", "No se encontraron publicaciones con esos filtros.")

    +publicationModal()

    script(src="/js/feed/infiniteScroll.js" type="module")
    script(src="/js/publication/publicationModal.js" type="module")
