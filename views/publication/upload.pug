extend ../layouts/app.pug
include ../components/win-border.pug
include ../components/icon.pug
include ../components/publicationView.pug

block app
    section(class="flex flex-col xl:flex-row xl:items-start xl:justify-center gap-6 w-full py-8 px-4")
        div(class="w-full xl:w-[38%] xl:max-w-xl shrink-0 bg-white border-2 border-black")

            div(class="flex items-center gap-2 bg-linear-to-r from-blue to-blue-l px-3 py-1")
                span(class="text-white")
                    +icon((mode === "edit" ? "gear" : "upload"), "w-5 h-5")
                h1(class="text-white font-bold text-sm")= (mode === "edit" ? "Editar publicacion - Fotaza 2" : "Subir nueva publicacion - Fotaza 2")

            script(id="upload-bootstrap" type="application/json")!= JSON.stringify({ mode, publication }).replace(/</g, "\\u003c")

            form(id="form-upload" class="flex flex-col gap-4 p-6")

                label(
                    id="dropzone"
                    for="images"
                    class="flex flex-col items-center justify-center gap-2 border-2 border-dashed border-win-gray bg-win-gray-l/40 py-10 px-4 cursor-pointer hover:bg-win-gray-l/60 transition-colors"
                )
                    span(class="text-win-gray")
                        +icon("camera", "w-12 h-12")
                    p(class="text-sm text-black") Arrastra y solta tus fotos aca
                    p(class="text-xs text-black opacity-60") o
                    span(class="text-sm text-black px-4 py-1 bg-win-gray/20 border border-black") Buscar archivos...
                    input(
                        type="file"
                        id="images"
                        name="images"
                        accept="image/*"
                        multiple
                        class="hidden"
                    )

                span#images-error(class="block text-red-500 text-sm h-4")

                div#previews(class="flex flex-col gap-2")

                button(
                    type="button"
                    id="btn-add-more"
                    class="hidden self-start text-sm text-blue-l hover:text-blue underline cursor-pointer"
                ) + Agregar mas imagenes

                div(class="flex flex-col gap-1")
                    label(for="title" class="text-sm text-black") Titulo
                        span(class="text-red-500") *
                    +winBorder("w-full")
                        input(
                            type="text"
                            id="title"
                            name="title"
                            placeholder="Ponele un titulo atractivo a tu publicacion"
                            class="text-black text-sm w-full px-2 py-1"
                        )
                    span#title-error(class="block text-red-500 text-sm h-4")

                div(class="flex flex-col gap-1")
                    label(for="description" class="text-sm text-black") Descripcion
                    +winBorder("w-full")
                        textarea(
                            id="description"
                            name="description"
                            placeholder="Contale a la gente sobre esta publicacion..."
                            class="text-black text-sm w-full h-24 resize-none px-2 py-1"
                        )

                div(class="flex flex-col gap-1")
                    label(for="tags" class="text-sm text-black") Etiquetas (separadas por coma)
                        span(class="text-red-500") *
                    +winBorder("w-full")
                        input(
                            type="text"
                            id="tags"
                            name="tags"
                            placeholder="atardecer, playa, naturaleza, fotografia"
                            class="text-black text-sm w-full px-2 py-1"
                        )
                    span#tags-error(class="block text-red-500 text-sm h-4")

                label(for="comments-enabled" class="flex items-center gap-2 cursor-pointer")
                    input(type="checkbox" id="comments-enabled" checked class="w-4 h-4 cursor-pointer")
                    span(class="text-sm text-black") Permitir comentarios

                div#form-error(class="text-red-500 text-sm text-center h-4")

                div(class="flex items-stretch gap-3")
                    +winBorder("w-full")
                        button(
                            type="submit"
                            id="btn-publish"
                            class="w-full px-4 py-2 bg-blue-l hover:bg-blue text-white text-sm cursor-pointer"
                        )= (mode === "edit" ? "Guardar cambios" : "Publicar")
                    +winBorder()
                        a(
                            href="/"
                            class="block px-6 py-2 bg-win-gray/30 hover:bg-win-gray/50 text-black text-sm"
                        ) Cancelar

        div(class="w-full xl:flex-1 xl:max-w-4xl")
            h2(class="text-black font-bold mb-3 text-lg") Vista previa
            +publicationView({ author: author }, true)

        script(src="/js/helpers/errors.js" type="module")
        script(src="/js/publication/upload.js" type="module")
